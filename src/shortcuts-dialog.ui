<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <object class="AdwShortcutsDialog" id="shortcuts_dialog">
    <child>
      <object class="AdwShortcutsSection">
        <property name="title" translatable="yes">Playback &amp; Output Control</property>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Play/Pause</property>
            <property name="accelerator">&lt;Ctrl&gt;p</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Next</property>
            <property name="accelerator">&lt;Shift&gt;period</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Previous</property>
            <property name="accelerator">&lt;Shift&gt;comma</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Seek Forward 10s</property>
            <property name="accelerator">&lt;Shift&gt;f</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Seek Backward 10s</property>
            <property name="accelerator">&lt;Shift&gt;b</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Stop</property>
            <property name="accelerator">&lt;Ctrl&gt;&lt;Shift&gt;s</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Toggle Random</property>
            <property name="accelerator">&lt;Alt&gt;z</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Toggle Repeat</property>
            <property name="accelerator">&lt;Alt&gt;r</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Toggle Single</property>
            <property name="accelerator">&lt;Alt&gt;y</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Toggle Consume</property>
            <property name="accelerator">&lt;Shift&gt;r</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Toggle ReplayGain</property>
            <property name="accelerator">&lt;Shift&gt;y</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Cycle Crossfade Duration</property>
            <property name="accelerator">&lt;Alt&gt;x</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Increase Volume 2%</property>
            <property name="accelerator">&lt;Ctrl&gt;Up</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Decrease Volume 2%</property>
            <property name="accelerator">&lt;Ctrl&gt;Down</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Toggle Mute</property>
            <property name="accelerator">&lt;Ctrl&gt;m</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Next Output Device</property>
            <property name="accelerator">&lt;Ctrl&gt;Right</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Previous Output Device</property>
            <property name="accelerator">&lt;Ctrl&gt;Left</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Toggle Current Output Device</property>
            <property name="accelerator">&lt;Ctrl&gt;/</property>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="AdwShortcutsSection">
        <property name="title" translatable="yes">Queue Control</property>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Stop &amp; Clear Queue</property>
            <property name="action-name">queue-view.stop-and-clear</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Save Current Queue</property>
            <property name="action-name">queue-view.save</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Jump to Current Song</property>
            <property name="action-name">queue-view.jump-to-current</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Toggle Queue Auto-scroll</property>
            <property name="action-name">queue-view.toggle-autoscroll</property>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="AdwShortcutsSection">
        <property name="title" translatable="yes">Views</property>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Jump to Recents</property>
            <property name="action-name">app.view-recent</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Jump to Album View</property>
            <property name="action-name">app.view-albums</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Jump to Artist View</property>
            <property name="action-name">app.view-artists</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Jump to Folder View</property>
            <property name="action-name">app.view-folders</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Jump to Dynamic Playlists</property>
            <property name="action-name">app.view-dynamic-playlists</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Jump to MPD Playlists</property>
            <property name="action-name">app.view-playlists</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Jump to Queue</property>
            <property name="action-name">app.view-queue</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Toggle Spectrum Visualiser</property>
            <property name="accelerator">F8</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Toggle Fullscreen</property>
            <property name="accelerator">F11</property>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="AdwShortcutsSection">
        <property name="title" translatable="yes">Playlist Editor</property>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Undo</property>
            <property name="accelerator">&lt;Ctrl&gt;z</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Redo</property>
            <property name="accelerator">&lt;Ctrl&gt;y</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Save</property>
            <property name="accelerator">&lt;Ctrl&gt;s</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Select Previous Track</property>
            <property name="accelerator">Up</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Select Next Track</property>
            <property name="accelerator">Down</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Shift Selected Track Backward</property>
            <property name="accelerator">&lt;Shift&gt;Up</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Shift Selected Track Forward</property>
            <property name="accelerator">&lt;Shift&gt;Down</property>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="AdwShortcutsSection">
        <property name="title" translatable="yes">Dynamic Playlist Editor</property>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Save</property>
            <property name="accelerator">&lt;Ctrl&gt;s</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Refresh</property>
            <property name="accelerator">&lt;Ctrl&gt;r</property>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="AdwShortcutsSection">
        <property name="title" translatable="yes">Other</property>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Refresh</property>
            <property name="accelerator">F5</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Update Database</property>
            <property name="accelerator">F6</property>
          </object>
        </child>
        <child>
          <object class="AdwShortcutsItem">
            <property name="title" translatable="yes">Quit</property>
            <property name="action-name">app.quit</property>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
